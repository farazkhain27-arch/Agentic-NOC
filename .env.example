# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# ── LangSmith ──────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-key-here
LANGCHAIN_PROJECT=noc-agentic-ai

# ── Database ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=noc_db
POSTGRES_USER=noc_user
POSTGRES_PASSWORD=changeme_secure_password

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JIRA ───────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=noc@your-org.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=NOC

# ── Email ──────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key
EMAIL_FROM=noc-alerts@your-org.com
EMAIL_MANAGEMENT=management@your-org.com

# ── Backend ────────────────────────────────────────────────
API_SECRET_KEY=change-this-to-a-random-64-char-secret
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── AWS ────────────────────────────────────────────────────
AWS_REGION=me-south-1
AWS_ACCOUNT_ID=123456789012

# ── NMS Simulator ─────────────────────────────────────────
NMS_ALARM_INTERVAL_SECONDS=30
NMS_SIMULATE=true
